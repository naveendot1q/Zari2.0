{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["bom1"],
  "functions": {
    "src/app/api/webhooks/**": {
      "maxDuration": 30
    },
    "src/app/api/orders/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ai/**": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
