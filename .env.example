# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Zari

# ─── Clerk (Auth) ──────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxx
CLERK_SECRET_KEY=sk_live_xxxx
CLERK_WEBHOOK_SECRET=whsec_xxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ─── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx
SUPABASE_JWT_SECRET=xxxx

# ─── Stripe ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxx
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# ─── Shiprocket ────────────────────────────────────────────────
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=yourpassword
SHIPROCKET_CHANNEL_ID=xxxx

# ─── Resend (Email) ────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_FROM_NAME=Zari

# ─── Pinecone (Vector Search) ──────────────────────────────────
PINECONE_API_KEY=xxxx
PINECONE_INDEX_NAME=zari-products
PINECONE_ENVIRONMENT=us-east-1

# ─── Upstash Redis (Cache) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ─── Anthropic / Claude AI ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── PostHog (Analytics) ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Sentry (Error Monitoring) ─────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxx
SENTRY_AUTH_TOKEN=xxxx
SENTRY_ORG=your-org
SENTRY_PROJECT=zari

# ─── Instagram / Meta ──────────────────────────────────────────
META_APP_ID=xxxx
META_APP_SECRET=xxxx
META_ACCESS_TOKEN=xxxx
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=xxxx
